# ===========================================================================
# InView3D — Environment Configuration
# Copy this file to `.env` and adjust values as needed.
# ===========================================================================

# ---- Ports ----------------------------------------------------------------
BACKEND_PORT=4000
FRONTEND_PORT=3000

# ---- Paths (relative to project root or absolute) -------------------------
UPLOAD_PATH=./uploads
OUTPUT_PATH=./output

# ---- Upload limits --------------------------------------------------------
# Maximum upload size in bytes (default 2 GB)
MAX_UPLOAD_SIZE=2147483648
# Maximum accepted video duration in seconds (default 5 minutes)
MAX_DURATION_SECONDS=300

# ---- Frame extraction -----------------------------------------------------
# Extract one frame every N seconds. May be fractional (0.5 => 2 fps).
# Lower = more frames = better overlap for SfM = slower. 0.5 is a good default;
# drop to 0.25 for fast walkthroughs.
FRAME_INTERVAL_SECONDS=0.5
# Alternatively cap the number of extracted frames (0 = unlimited)
MAX_FRAMES=300

# ---- Processing -----------------------------------------------------------
# Number of CPU threads the pipeline may use (0 = auto/all cores)
PROCESSING_THREADS=0
# Absolute path to the pipeline scripts directory (leave blank to auto-detect)
PIPELINE_SCRIPTS_DIR=
# Binaries (override if not on PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
COLMAP_BIN=colmap
OPENMVS_BIN_DIR=

# ---- Redis / BullMQ -------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- CORS -----------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---- Frontend (Next.js public vars) ---------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
